# contract-rag — example environment configuration
# Copy to `.env` and fill in what you need. `.env` is gitignored and auto-loaded
# by `get_settings()` (src/contract_rag/config.py); real shell env vars always
# take precedence over `.env` values. Nothing here is required to run the unit
# test suite — only the credential-free `rule`/`fake` backends and in-memory
# stores are exercised by default.

# ---------------------------------------------------------------------------
# Core extraction backend
# ---------------------------------------------------------------------------
# fake (empty, default) | rule (deterministic regex, credential-free, CI default)
# | openai (gated, see ALLOW_EXTERNAL_LLM) | local (vLLM/SGLang) | mlx (Ollama)
# | constrained (schema-constrained decoding over any OpenAI-compatible server)
EXTRACT_BACKEND=rule

# Which vertical package to use: contract (default) | nda
VERTICAL=contract

# Must be "true" to allow EXTRACT_BACKEND=openai or a non-local local/mlx/
# constrained endpoint — governs whether documents may leave your network.
# Never weaken this gate; see config.assert_backend_allowed().
ALLOW_EXTERNAL_LLM=false

# --- openai backend (gated by ALLOW_EXTERNAL_LLM) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- local backend: vLLM/SGLang OpenAI-compatible endpoint (ungated, on-device) ---
LOCAL_ENDPOINT=http://localhost:8000/v1
LOCAL_MODEL=Qwen3-14B

# --- mlx backend: Ollama OpenAI-compatible endpoint (ungated, on-device) ---
MLX_ENDPOINT=http://localhost:11434/v1
MLX_MODEL=qwen3

# --- constrained backend: any OpenAI-compatible server with json_schema
# structured output (vLLM/SGLang/Ollama >= 0.5). Falls back to
# LOCAL_ENDPOINT/LOCAL_MODEL when unset.
CONSTRAINED_ENDPOINT=
CONSTRAINED_MODEL=

# ---------------------------------------------------------------------------
# Parsing
# ---------------------------------------------------------------------------
# SGLang VLM endpoint for the vision-language OCR fallback route
VLM_ENDPOINT=
VLM_TIMEOUT=1200

# Path/name of the optional focr CPU-only OCR binary (opt-in spike adapter)
FRANKEN_BIN=

# Text-coverage fraction (pypdfium2 probe) above which a page/doc routes to
# docling instead of paddleocr/vlm
TEXT_COVERAGE_THRESHOLD=0.8

# ---------------------------------------------------------------------------
# General app behavior
# ---------------------------------------------------------------------------
REDACT_PII=true
MAX_UPLOAD_MB=25

# ---------------------------------------------------------------------------
# Data / golden-set locations (all gitignored)
# ---------------------------------------------------------------------------
DATA_DIR=data
GOLDEN_SET_DIR=golden_set
CUAD_DIR=cuad
KLEISTER_DIR=kleister-nda
KLEISTER_DATA_DIR=data_nda_kleister
KLEISTER_GOLDEN_DIR=golden_set_nda_kleister

# Caps how many docs eval/cuad.py and verticals/nda/kleister.py build (defaults
# vary per script; see CLAUDE.md for exact defaults)
GOLDEN_SET_SIZE=
KLEISTER_SET_SIZE=

# ---------------------------------------------------------------------------
# Retrieval / indexing
# ---------------------------------------------------------------------------
# hashing (non-semantic, default/CI) | openai (gated, needs OPENAI_API_KEY +
# ALLOW_EXTERNAL_LLM)
EMBED_BACKEND=hashing
RETRIEVAL_K=5

# Postgres+pgvector DSN for the PgVectorStore adapter (gated integration tests
# only; in-memory store is the default everywhere else)
PGVECTOR_URL=

# ---------------------------------------------------------------------------
# Eval harnesses (each gated on its own dataset directory; unset = skipped)
# ---------------------------------------------------------------------------
IR_CACHE_DIR=.ir_cache
STATS_CI=
INJECT_DEFS=

REALSCAN_DIR=
REALSCAN_GT_DIR=
REALSCAN_SET_SIZE=
REALSCAN_OUT=
REALSCAN_CACHE=

FINCRITICAL_DIR=
FINCRITICAL_SET_SIZE=
FINCRITICAL_OUT=
FINCRITICAL_CACHE=

SIGNATURE_DIR=
SIGNATURE_GT_DIR=
SIGNATURE_CACHE=
SIGNATURE_SET_SIZE=
SIGNATURE_OUT=

COVERAGE_DATASET=
COVERAGE_SET_SIZE=
COVERAGE_DPI=
COVERAGE_DILATE=
COVERAGE_BORDER=
COVERAGE_OUT=

EDITH_DIR=
EDITH_SET_SIZE=
EDITH_PARSE_SIZE=
EDITH_OUT=
EDITH_CACHE=

DEGRADE_LEVEL=light
DEGRADE_SET_SIZE=
DEGRADE_MAX_PAGES=
DEGRADE_SEED=
DEGRADE_RENDER_DPI=
DEGRADE_CACHE=
DEGRADE_OUT=

# ---------------------------------------------------------------------------
# Demo / report / export
# ---------------------------------------------------------------------------
REPORT_OUT=
EXPORT_FACTS=
EXPORT_CLM=

TRACE_OUT=traces.jsonl
TRACE_RENDER=

# ---------------------------------------------------------------------------
# Benchmark / static site build
# ---------------------------------------------------------------------------
BENCHMARK_OUT=benchmark_out
BENCHMARK_SEED=0
SITE_OUT=site_out
SITE_BASE_URL=
